XSL_GROUP_KEY=concat(footprint, ':', value, ':', fields/field[@name='PartNo'], ':', fields/field[@name='ValueAlt'])
define bom2csv_xsl
<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" version="1.0">
	<xsl:output method="text"/>
	<xsl:key name="partGroup" match="comp" use="${XSL_GROUP_KEY}" />
	<xsl:template match="/export">
		<xsl:text>Refs,Value,Footprint,Qty&#10;</xsl:text>
		<xsl:for-each select="components/comp[count(. | key('partGroup', ${XSL_GROUP_KEY})[1]) = 1]">
			<!-- REFERENCES -->
			<!-- <xsl:sort select="@ref" /> -->
			<xsl:for-each select="key('partGroup', ${XSL_GROUP_KEY})">
				<xsl:value-of select="@ref"/>
				<xsl:text> </xsl:text>
			</xsl:for-each>
			<xsl:text>,"</xsl:text>
			<!-- VALUE -->
            <xsl:variable name="valueString">
                <xsl:if test="not(fields/field[@name='PartNo'])">
					<xsl:value-of select="value"/>
	                <xsl:if test="fields/field[@name='ValueAlt'] != ''">
	                    <xsl:text>, </xsl:text>
	                </xsl:if>
				</xsl:if>
                <xsl:value-of select="fields/field[@name='PartNo']"/>
                <xsl:if test="fields/field[@name='PartNo'] and fields/field[@name='ValueAlt']">
                    <xsl:text>, </xsl:text>
                </xsl:if>
                <xsl:value-of select="fields/field[@name='ValueAlt']"/>
                <xsl:if test="fields/field[@name='PartNo']">
                	<xsl:text>, \(</xsl:text>
                	<xsl:value-of select="value"/>
                    <xsl:text>)</xsl:text>
                </xsl:if>
            </xsl:variable>
            <xsl:call-template name="replaceCommaWithNewline">
                <xsl:with-param name="text" select="$$valueString"/>
            </xsl:call-template>
			<xsl:text>","</xsl:text>
			<!-- FOOTPRINT -->
			<xsl:value-of select="substring-after(footprint,':')" />
			<xsl:text>",</xsl:text>
			<!-- QTY -->
			<xsl:value-of select="count(key('partGroup', ${XSL_GROUP_KEY}))"/>
			<xsl:text>&#10;</xsl:text>
		</xsl:for-each>
	</xsl:template>
	<xsl:template name="replaceCommaWithNewline">
		<xsl:param name="text"/>
		<xsl:choose>
			<xsl:when test="contains($$text, ', ')">
				<xsl:value-of select="substring-before($$text, ', ')"/>
				<xsl:text>&#10;&#10;</xsl:text>
				<xsl:call-template name="replaceCommaWithNewline">
					<xsl:with-param name="text" select="substring-after($$text, ', ')"/>
				</xsl:call-template>
			</xsl:when>
			<xsl:otherwise>
				<xsl:value-of select="$$text"/>
			</xsl:otherwise>
		</xsl:choose>
	</xsl:template>
</xsl:stylesheet>
endef


